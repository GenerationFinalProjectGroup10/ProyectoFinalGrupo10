--- !u!114 &1312767586
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1312767585}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0482b97448194004cad37315b9406e78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewMonoBehaviourScript
  nameText: {fileID: 1489866778}
  dialogueText: {fileID: 1874229177}
  speakerIcon: {fileID: 1075236965}
  choicesPanel: {fileID: 681031710}
  choiceButtons:
  - {fileID: 1257306214}
  - {fileID: 1843270360}
  - {fileID: 1649389300}
  dialogueCanvasGroup: {fileID: 1206556111}
  fadeDuration: 2
  delayBeforeStart: 3
  audioSource: {fileID: 0}
  typingSpeed: 0.03
  nodes:
  - characterName: Madre
    characterIcon: {fileID: 0}
    nameColor: {r: 0.7803922, g: 0.08235294, b: 0.5215687, a: 1}
    dialogueText: "Es mejor empezar de nuevo, \xBFno crees?"
    options:
    - optionText: No
      responseText: "No siempre elegimos\u2026 pero seguimos adelante."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.5411765, g: 0.1686275, b: 0.8862746, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No me gusta este lugar
      responseText: Solo dale una oportunidad.
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: "S\xED"
      responseText: "Eso es\u2026 todo va a estar bien."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  - characterName: Madre
    characterIcon: {fileID: 0}
    nameColor: {r: 1, g: 1, b: 1, a: 1}
    dialogueText: "\xBFTe gusta la casa nueva?"
    options:
    - optionText: "S\xED"
      responseText: "Me alegra\u2026 sab\xEDa que te gustar\xEDa."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No mucho
      responseText: "Bueno\u2026 ya te vas a acostumbrar."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: Quiero volver
      responseText: "\u2026No podemos volver."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 0}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
