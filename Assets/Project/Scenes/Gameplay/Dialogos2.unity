  m_Script: {fileID: 11500000, guid: 0482b97448194004cad37315b9406e78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewMonoBehaviourScript
  nameText: {fileID: 844289430}
  dialogueText: {fileID: 912600269}
  speakerIcon: {fileID: 105549119}
  choicesPanel: {fileID: 286567269}
  choiceButtons:
  - {fileID: 1196201254}
  - {fileID: 1764435606}
  - {fileID: 1828771425}
  dialogueCanvasGroup: {fileID: 369953874}
  fadeDuration: 2
  delayBeforeStart: 3
  audioSource: {fileID: 0}
  typingSpeed: 0.03
  nodes:
  - characterName: Madre
    characterIcon: {fileID: 21300000, guid: 7f6c7783a47f72648b790be199e9d902, type: 3}
    nameColor: {r: 0.4339623, g: 0.07164471, b: 0.29961976, a: 1}
    dialogueText: "\xBFQuieres entrar?"
    options:
    - optionText: si
      responseText: "Bien\u2026 no tiene sentido esperar."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.5411765, g: 0.1686275, b: 0.8862746, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No quiero entrar
      responseText: "\u2026Tendr\xE1s que hacerlo."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  - characterName: Madre
    characterIcon: {fileID: 21300000, guid: 7f6c7783a47f72648b790be199e9d902, type: 3}
    nameColor: {r: 0.43529412, g: 0.07450981, b: 0.3019608, a: 1}
    dialogueText: Vamos, entra
    options:
    - optionText: (Entrar en silencio)
      responseText: "As\xED est\xE1 bien"
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: Voy contigo
      responseText: Claro, ven.
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: "\xBFT\xFA primero?"
      responseText: "\u2026Est\xE1 bien."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  - characterName: Madre
    characterIcon: {fileID: 21300000, guid: 7f6c7783a47f72648b790be199e9d902, type: 3}
    nameColor: {r: 0.43529412, g: 0.07450981, b: 0.3019608, a: 1}
    dialogueText: "Ve a tu habitaci\xF3n a dormir ya es tarde."
    options:
    - optionText: "Est\xE1 bien"
      responseText: "Gracias, cari\xF1o."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No quiero ir sola
      responseText: "Est\xE1 al fondo, no pasa nada."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  sceneFader: {fileID: 1520700572}
  nextSceneName: Mundo1
  usePauseSystem: 1
  pauseEndFade: 1
  waitingExternalResume: 0
