  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0482b97448194004cad37315b9406e78, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NewMonoBehaviourScript
  nameText: {fileID: 1518931153}
  dialogueText: {fileID: 1040675431}
  speakerIcon: {fileID: 1102317372}
  choicesPanel: {fileID: 896323350}
  choiceButtons:
  - {fileID: 1848724332}
  - {fileID: 796621542}
  - {fileID: 520563422}
  dialogueCanvasGroup: {fileID: 164523257}
  fadeDuration: 2
  delayBeforeStart: 3
  audioSource: {fileID: 0}
  typingSpeed: 0.03
  nodes:
  - characterName: Madre
    characterIcon: {fileID: 21300000, guid: 7f6c7783a47f72648b790be199e9d902, type: 3}
    nameColor: {r: 0.4339623, g: 0.07164471, b: 0.29961976, a: 1}
    dialogueText: "Es mejor empezar de nuevo, \xBFno crees?"
    options:
    - optionText: No
      responseText: "No siempre elegimos\u2026 pero seguimos adelante."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.5411765, g: 0.1686275, b: 0.8862746, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No me gusta este lugar
      responseText: Solo dale una oportunidad.
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: "S\xED"
      responseText: "Eso es\u2026 todo va a estar bien."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  - characterName: Madre
    characterIcon: {fileID: 21300000, guid: 7f6c7783a47f72648b790be199e9d902, type: 3}
    nameColor: {r: 0.43529412, g: 0.07450981, b: 0.3019608, a: 1}
    dialogueText: "\xBFTe gusta la casa nueva?"
    options:
    - optionText: "S\xED"
      responseText: "Me alegra\u2026 sab\xEDa que te gustar\xEDa."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: No mucho
      responseText: "Bueno\u2026 ya te vas a acostumbrar."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    - optionText: Quiero volver
      responseText: "\u2026No podemos volver."
      responseCharacterName: Maria
      responseCharacterIcon: {fileID: 21300000, guid: 3678cc30cabbd1849aeae34d01800db9, type: 3}
      responseNameColor: {r: 0.4, g: 0.2, b: 0.6, a: 1}
      responseVoiceClip: {fileID: 0}
    voiceClip: {fileID: 0}
  sceneFader: {fileID: 1616622543}
  nextSceneName: Mundo1
